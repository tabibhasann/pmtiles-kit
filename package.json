{
  "name": "@tabibhasan/pmtiles-kit",
  "version": "0.2.0",
  "description": "The missing Swiss-army knife for PMTiles and MBTiles — inspect, validate, convert, and preview map tile archives",
  "license": "MIT",
  "author": "Tabib Hasan",
  "homepage": "https://github.com/tabibhasann/pmtiles-kit#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/tabibhasann/pmtiles-kit.git"
  },
  "bugs": {
    "url": "https://github.com/tabibhasann/pmtiles-kit/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "pmtiles-kit": "./dist/cli.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md",
    "ROADMAP.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "pmtiles",
    "mbtiles",
    "maps",
    "tiles",
    "gis",
    "geospatial",
    "cli",
    "inspect",
    "validate",
    "convert",
    "preview",
    "map-tiles",
    "tile-archive",
    "vector-tiles",
    "raster-tiles",
    "open-source",
    "developer-tools"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ test/",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run lint && npm test"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "pmtiles": "^3.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
